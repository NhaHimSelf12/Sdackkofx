APP_NAME="FX Command"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

DB_CONNECTION=sqlite
# For MySQL instead of SQLite:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=forex
# DB_USERNAME=root
# DB_PASSWORD=

CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

# ---------------------------------------------------------------
# AI market analysis (optional)
# If empty, the app falls back to the built-in technical engine
# (EMA trend + RSI + market structure heuristics).
# ---------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------
# Live market data (optional)
# Get a free key at https://twelvedata.com
# If empty, the app generates realistic demo candles.
# ---------------------------------------------------------------
TWELVEDATA_API_KEY=

# ---------------------------------------------------------------
# Live financial news (optional)
# Get a free key at https://newsapi.org
# If empty, the app uses seeded demo news.
# ---------------------------------------------------------------
NEWSAPI_KEY=
